{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/post-push-ci-watch.sh",
            "if": "Bash(git push*)",
            "timeout": 10,
            "statusMessage": "Arming post-push CI watch..."
          }
        ]
      }
    ]
  }
}
