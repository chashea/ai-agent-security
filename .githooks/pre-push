#!/usr/bin/env bash
# Pre-push hook: run the full CI suite locally before pushing to main.
#
# Mirrors the six jobs in .github/workflows/validate.yml so broken
# pushes don't waste 5+ minutes of CI time. Runs:
#   - ruff check scripts/                      (python-lint)
#   - python3.12 -m pytest scripts/tests/      (python-test)
#   - PSScriptAnalyzer (Warning level)         (lint)
#   - Invoke-Pester tests/                     (test)
#   - az bicep build <each template>           (bicep-validate)
#   - Import modules + validate config         (smoke-test)
#
# Bypass: git push --no-verify  (only when the user explicitly asks).
# Skip an individual job via env var: SKIP_PYTEST=1, SKIP_PESTER=1,
# SKIP_BICEP=1, SKIP_PSSA=1, SKIP_SMOKE=1.
#
# Opt-in adversarial smoke check (requires live AI Gateway + az login):
# RUN_ADVERSARIAL_SMOKE=1 — fires prompt_injection x 5 agents and asserts
# 100% jailbreak classifier coverage.

set -euo pipefail
cd "$(dirname "$0")/.."

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

fail=0
started=$(date +%s)

step() { echo -e "${YELLOW}[pre-push] $1${NC}"; }
ok()   { echo -e "${GREEN}[pre-push] ok: $1${NC}"; }
bad()  { echo -e "${RED}[pre-push] FAIL: $1${NC}"; fail=1; }

# ── python-lint ─────────────────────────────────────────────────────────────
step "ruff check scripts/"
if command -v ruff >/dev/null 2>&1; then
    ruff check scripts/ || bad "ruff check"
else
    echo -e "${YELLOW}ruff not installed — skipping. Install: pip install ruff${NC}"
fi

# ── python-test ─────────────────────────────────────────────────────────────
if [ "${SKIP_PYTEST:-}" = "1" ]; then
    echo -e "${YELLOW}[pre-push] pytest skipped (SKIP_PYTEST=1)${NC}"
elif command -v python3.12 >/dev/null 2>&1; then
    step "pytest scripts/tests/"
    # -q: quiet; retry-based tests are intentionally slow (~60s) but should pass.
    python3.12 -m pytest scripts/tests/ -q || bad "pytest"
else
    echo -e "${RED}python3.12 not found — cannot run pytest.${NC}"
    bad "pytest (missing python3.12)"
fi

# ── PSScriptAnalyzer (lint) ─────────────────────────────────────────────────
if [ "${SKIP_PSSA:-}" = "1" ]; then
    echo -e "${YELLOW}[pre-push] PSScriptAnalyzer skipped (SKIP_PSSA=1)${NC}"
elif command -v pwsh >/dev/null 2>&1; then
    step "PSScriptAnalyzer (Warning, repo-wide)"
    pwsh -NoProfile -Command "
        \$ErrorActionPreference = 'Stop'
        if (-not (Get-Module -ListAvailable -Name PSScriptAnalyzer)) {
            Write-Host 'PSScriptAnalyzer not installed. Run: Install-Module -Name PSScriptAnalyzer -Force -Scope CurrentUser' -ForegroundColor Red
            exit 1
        }
        \$results = Invoke-ScriptAnalyzer -Path . -Recurse -Severity Warning -ExcludeRule PSAvoidUsingWriteHost,PSUseSingularNouns,PSUseBOMForUnicodeEncodedFile
        if (\$results) {
            \$results | Format-Table -AutoSize
            Write-Host \"PSScriptAnalyzer found \$(\$results.Count) issue(s)\" -ForegroundColor Red
            exit 1
        }
        Write-Host 'PSScriptAnalyzer: clean' -ForegroundColor Green
    " || bad "PSScriptAnalyzer"
else
    echo -e "${YELLOW}pwsh not found — skipping PSScriptAnalyzer${NC}"
fi

# ── Pester (test) ───────────────────────────────────────────────────────────
if [ "${SKIP_PESTER:-}" = "1" ]; then
    echo -e "${YELLOW}[pre-push] Pester skipped (SKIP_PESTER=1)${NC}"
elif command -v pwsh >/dev/null 2>&1; then
    step "Pester tests/"
    pwsh -NoProfile -Command "
        \$ErrorActionPreference = 'Stop'
        if (-not (Get-Module -ListAvailable -Name Pester | Where-Object { \$_.Version -ge [version]'5.0' })) {
            Write-Host 'Pester 5+ not installed. Run: Install-Module -Name Pester -Force -Scope CurrentUser -MinimumVersion 5.0' -ForegroundColor Red
            exit 1
        }
        \$result = Invoke-Pester tests/ -Output Minimal -PassThru
        if (\$result.FailedCount -gt 0) {
            Write-Host \"Pester: \$(\$result.FailedCount) test(s) failed\" -ForegroundColor Red
            exit 1
        }
        Write-Host \"Pester: \$(\$result.PassedCount) passed\" -ForegroundColor Green
    " || bad "Pester"
fi

# ── bicep-validate ──────────────────────────────────────────────────────────
if [ "${SKIP_BICEP:-}" = "1" ]; then
    echo -e "${YELLOW}[pre-push] bicep skipped (SKIP_BICEP=1)${NC}"
elif command -v az >/dev/null 2>&1; then
    step "az bicep build (infra/*.bicep)"
    bicep_ok=1
    for f in infra/*.bicep; do
        [ -f "$f" ] || continue
        if ! az bicep build --file "$f" >/dev/null 2>&1; then
            echo -e "${RED}bicep build failed: $f${NC}"
            az bicep build --file "$f" || true
            bicep_ok=0
        fi
    done
    if [ $bicep_ok -eq 1 ]; then
        ok "bicep"
    else
        bad "bicep"
    fi
else
    echo -e "${YELLOW}az CLI not found — skipping bicep build${NC}"
fi

# ── smoke-test ──────────────────────────────────────────────────────────────
if [ "${SKIP_SMOKE:-}" = "1" ]; then
    echo -e "${YELLOW}[pre-push] smoke-test skipped (SKIP_SMOKE=1)${NC}"
elif command -v pwsh >/dev/null 2>&1; then
    step "smoke-test (module imports + config validation)"
    pwsh -NoProfile -Command "
        \$ErrorActionPreference = 'Stop'
        foreach (\$mod in Get-ChildItem modules/*.psm1) {
            Import-Module \$mod.FullName -Force
        }
        \$config = Import-LabConfig -ConfigPath config.json
        \$valid = Test-LabConfigValidity -Config \$config
        if (-not \$valid) { Write-Host 'Config invalid' -ForegroundColor Red; exit 1 }
        Write-Host 'smoke-test: ok' -ForegroundColor Green
    " || bad "smoke-test"
fi

# ── Adversarial smoke (gateway prompt-injection coverage check) ─────────────
# Opt-in: set RUN_ADVERSARIAL_SMOKE=1 to fire the prompt_injection slice
# (5 attacks x 5 agents = 25 calls, ~30-60s) through the AI Gateway and
# assert 100% jailbreak classifier coverage. Catches regressions in the
# RAI guardrail tuning or in the gateway policy XML.
#
# Requires: az login active, manifest with aiGateway.starterSubscriptionKey,
# python3.12 + scripts/requirements.txt installed.
if [ "${RUN_ADVERSARIAL_SMOKE:-}" = "1" ]; then
    if ! command -v python3.12 >/dev/null 2>&1; then
        echo -e "${YELLOW}[pre-push] adversarial-smoke skipped (python3.12 missing)${NC}"
    elif ! ls manifests/*.json >/dev/null 2>&1; then
        echo -e "${YELLOW}[pre-push] adversarial-smoke skipped (no manifests/)${NC}"
    elif ! az account show --query id -o tsv >/dev/null 2>&1; then
        echo -e "${YELLOW}[pre-push] adversarial-smoke skipped (az login required)${NC}"
    else
        # Threshold 0.9: tolerate the occasional agent-refusal that pre-empts
        # the filter (e.g. a polite "I can't help with that" before Prompt
        # Shields verdicts). A real RAI tuning regression drops the rate
        # well below 0.9, so this still catches drift.
        step "adversarial-smoke (prompt_injection x 5 agents, ≥90% jailbreak coverage)"
        smoke_log="logs/smoke_pre-push_$(date +%Y%m%d_%H%M%S).log"
        smoke_json="logs/smoke_pre-push_$(date +%Y%m%d_%H%M%S).json"
        if python3.12 scripts/attack_via_gateway.py \
            --category prompt_injection \
            --sleep-between 0.3 \
            --assert --min-coverage 0.9 \
            --output "$smoke_json" >"$smoke_log" 2>&1; then
            ok "adversarial-smoke"
        else
            echo -e "${RED}adversarial-smoke output:${NC}"
            tail -25 "$smoke_log"
            bad "adversarial-smoke"
        fi
    fi
fi

elapsed=$(( $(date +%s) - started ))

if [ $fail -ne 0 ]; then
    echo -e "${RED}[pre-push] blocked after ${elapsed}s. Fix errors above or --no-verify (if explicitly instructed).${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-push] ok in ${elapsed}s${NC}"
exit 0
