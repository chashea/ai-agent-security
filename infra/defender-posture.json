{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "12241104575715705731"
    }
  },
  "parameters": {
    "enableStorageDefender": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable Defender for Storage Accounts"
      }
    },
    "enableAppServiceDefender": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable Defender for App Services"
      }
    },
    "enableKeyVaultDefender": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable Defender for Key Vaults"
      }
    },
    "enableArmDefender": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable Defender for ARM (Resource Manager)"
      }
    },
    "enableAIDefender": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Enable Defender for AI services (Data security for AI interactions)"
      }
    }
  },
  "resources": [
    {
      "condition": "[parameters('enableStorageDefender')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "StorageAccounts",
      "properties": {
        "pricingTier": "Standard"
      }
    },
    {
      "condition": "[parameters('enableAppServiceDefender')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "AppServices",
      "properties": {
        "pricingTier": "Standard"
      }
    },
    {
      "condition": "[parameters('enableKeyVaultDefender')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "KeyVaults",
      "properties": {
        "pricingTier": "Standard"
      }
    },
    {
      "condition": "[parameters('enableArmDefender')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "Arm",
      "properties": {
        "pricingTier": "Standard"
      }
    },
    {
      "condition": "[parameters('enableAIDefender')]",
      "type": "Microsoft.Security/pricings",
      "apiVersion": "2024-01-01",
      "name": "AI",
      "properties": {
        "pricingTier": "Standard",
        "extensions": [
          {
            "name": "AIModelScanner",
            "isEnabled": "True"
          },
          {
            "name": "AIPromptEvidence",
            "isEnabled": "True"
          },
          {
            "name": "AIPromptSharingWithPurview",
            "isEnabled": "True"
          }
        ]
      }
    }
  ]
}