    "blocklistName": {
      "type": "string",
      "defaultValue": "aisec-sensitive-data"
    }
  },
  "variables": {
    "coreFilters": [
      {
        "name": "hate",
        "source": "Prompt",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "hate",
        "source": "Completion",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "sexual",
        "source": "Prompt",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "sexual",
        "source": "Completion",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "violence",
        "source": "Prompt",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "violence",
        "source": "Completion",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "selfharm",
        "source": "Prompt",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "selfharm",
        "source": "Completion",
        "severityThreshold": "Low",
        "blocking": true,
        "enabled": true
      }
    ],
    "promptProtection": [
      {
        "name": "jailbreak",
        "source": "Prompt",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "indirect_attack",
        "source": "Prompt",
        "blocking": true,
        "enabled": true
      }
    ],
    "materialProtection": [
      {
        "name": "protected_material_text",
        "source": "Completion",
        "blocking": true,
        "enabled": true
      },
      {
        "name": "protected_material_code",
        "source": "Completion",
        "blocking": true,
        "enabled": true
      }
    ],
    "piiFilters": [
      {
        "name": "pii",
        "source": "Prompt",
        "blocking": false,
        "enabled": true
      },
      {
        "name": "pii",
        "source": "Completion",
        "blocking": false,
        "enabled": true
      }
    ],
    "profanityFilter": [
      {
        "name": "profanity",
        "source": "Prompt",
        "blocking": true,
        "enabled": true
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.CognitiveServices/accounts/raiBlocklists",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', parameters('accountName'), parameters('blocklistName'))]",
      "properties": {
        "description": "Blocks PII patterns (SSN, credit cards, bank accounts) in prompts and completions"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/raiBlocklists/raiBlocklistItems",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}/{2}', parameters('accountName'), parameters('blocklistName'), 'ssn-pattern')]",
      "properties": {
        "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b",
        "isRegex": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/raiBlocklists', parameters('accountName'), parameters('blocklistName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/raiBlocklists/raiBlocklistItems",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}/{2}', parameters('accountName'), parameters('blocklistName'), 'credit-card-pattern')]",
      "properties": {
        "pattern": "\\b(?:4\\d{3}|5[1-5]\\d{2}|3[47]\\d{2}|6(?:011|5\\d{2}))[-\\s]?\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{3,4}\\b",
        "isRegex": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/raiBlocklists', parameters('accountName'), parameters('blocklistName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/raiBlocklists/raiBlocklistItems",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}/{2}', parameters('accountName'), parameters('blocklistName'), 'bank-account-keyword')]",
      "properties": {
        "pattern": "my (bank|routing) (account|number) is",
        "isRegex": true
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/raiBlocklists', parameters('accountName'), parameters('blocklistName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/raiPolicies",
      "apiVersion": "2024-10-01",
      "name": "[format('{0}/{1}', parameters('accountName'), parameters('policyName'))]",
      "properties": {
        "basePolicyName": "Microsoft.DefaultV2",
        "mode": "Blocking",
        "contentFilters": "[concat(variables('coreFilters'), variables('promptProtection'), variables('materialProtection'), variables('piiFilters'), variables('profanityFilter'))]",
        "customBlocklists": [
          {
            "blocklistName": "[parameters('blocklistName')]",
            "blocking": true,
            "source": "Prompt"
          },
          {
            "blocklistName": "[parameters('blocklistName')]",
            "blocking": true,
            "source": "Completion"
          }
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/raiBlocklists', parameters('accountName'), parameters('blocklistName'))]"
      ]
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
      "apiVersion": "2026-01-15-preview",
      "name": "[format('{0}/{1}', parameters('accountName'), parameters('modelDeploymentName'))]",
      "sku": {
        "name": "GlobalStandard",
        "capacity": 10
      },
      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o",
          "version": "2024-11-20"
        },
        "raiPolicyName": "[parameters('policyName')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CognitiveServices/accounts/raiPolicies', parameters('accountName'), parameters('policyName'))]"
      ]
    }
  ],
  "outputs": {
    "raiPolicyName": {
      "type": "string",
      "value": "[parameters('policyName')]"
    },
    "blocklistName": {
      "type": "string",
      "value": "[parameters('blocklistName')]"
    },
    "modelDeploymentName": {
      "type": "string",
      "value": "[parameters('modelDeploymentName')]"
    }
  }
}