      "properties": {
        "model": {
          "format": "OpenAI",
          "name": "gpt-4o",
          "version": "2024-11-20"
        },
        "raiPolicyName": "[parameters('weakRaiPolicyName')]"
      }
    },
    {
      "type": "Microsoft.CognitiveServices/accounts/deployments",
